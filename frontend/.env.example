VITE_API_URL=http://localhost:4000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Feature Flags
VITE_USE_NEW_ONBOARDING=false

# OneSignal Push Notifications (Requirement 15.2)
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id

# Game Data URL (Bug 1.24)
VITE_GAME_DATA_URL=/initialGameData.json

# BUG FIX (Bug #1): CSRF secret moved to backend-only
# CSRF tokens are now fetched from GET /api/auth/csrf-token
# No frontend environment variable needed
